NEXT_PUBLIC_SANITY_PROJECT_ID=r1yazroc
NEXT_PUBLIC_SANITY_DATASET=production

# Set to 1 to disable local brand font and use system UI stack for --font-body (staging / rollback).
# NEXT_PUBLIC_BRAND_FONT_DISABLED=1

# Sanity preview (server-side, never expose in frontend bundles)
# SANITY_API_READ_TOKEN=your-sanity-read-token
# SANITY_PREVIEW_SECRET=your-shared-preview-secret

# Studio-visible secret for the explicit "Open preview" button in Links view.
# Keep equal to SANITY_PREVIEW_SECRET.
# SANITY_STUDIO_PREVIEW_SECRET=your-shared-preview-secret

## HubSpot Integration

- **Portal ID:** 147410570
- **Region:** eu1
- **Script:** //js-eu1.hsforms.net/forms/embed/v2.js
- **Tracking Code:** //js-eu1.hs-scripts.com/147410570.js (should be on all pages)

Embed forms client-side using:
```tsx
'use client';
import { useEffect } from 'react';

export default function HubSpotForm({ formId }: { formId: string }) {
  useEffect(() => {
    const script = document.createElement('script');
    script.src = '//js-eu1.hsforms.net/forms/embed/v2.js';
    script.async = true;
    script.onload = () => {
      window.hbspt?.forms.create({
        portalId: '147410570',
        formId,
        target: '#hubspot-form',
        region: 'eu1',
      });
    };
    document.body.appendChild(script);
    return () => { document.body.removeChild(script); };
  }, [formId]);

  return <div id="hubspot-form" />;
}
```

